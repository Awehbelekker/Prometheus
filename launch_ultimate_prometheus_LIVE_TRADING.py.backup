                title="Prometheus Ultimate Trading System",
                description="ALL 80+ Revolutionary Systems with Live Trading",
                version="1.0.0"
            )

            # Add CORS middleware
            self.app.add_middleware(
                CORSMiddleware,
                allow_origins=["*"],
                allow_credentials=True,
                allow_methods=["*"],
                allow_headers=["*"],
