# =============================================================================
# PROMETHEUS TRADING PLATFORM - UNIFIED CONFIGURATION TEMPLATE
# Single source of truth for all environment variables
# Copy to .env and customize for your deployment
# =============================================================================

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================
ENVIRONMENT=development
# Options: development, production, testing

# Server Configuration
HOST=127.0.0.1
PORT=8000
FRONTEND_PORT=3000
WORKERS=1
RELOAD=true

# Deployment Mode
DOCKER_MODE=false
KUBERNETES_MODE=false

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Primary Database
DATABASE_URL=sqlite:///prometheus_trading.db
# For PostgreSQL: postgresql://user:password@localhost:5432/prometheus

# Additional Databases
MASS_FRAMEWORK_DB=sqlite:///ai_development_mass_framework/mass_framework.db
ANALYTICS_DB=sqlite:///analytics.db

# Database Options
AUTO_MIGRATE=false
MIGRATION_STRICT=false
SCHEMA_STRICT=false

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# JWT Configuration
JWT_SECRET_KEY=your-super-secure-jwt-secret-key-here
JWT_EXPIRATION_HOURS=24
JWT_ALGORITHM=HS256

# Password Security
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=false

# Session Management
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
CONCURRENT_SESSIONS_LIMIT=3

# Multi-Factor Authentication
MFA_ENABLED=false
MFA_REQUIRED_FOR_ADMIN=true
MFA_ISSUER=PROMETHEUS Trading

# Enterprise Security
ENTERPRISE_MODE=false
RISK_ASSESSMENT_ENABLED=false
AUDIT_LOGGING_ENABLED=true
SECURITY_HEADERS_ENABLED=true

# API Security
API_RATE_LIMIT_PER_MINUTE=60
API_RATE_LIMIT_BURST=10
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================
# Broker Configuration (Alpaca)
ALPACA_API_KEY=your-alpaca-api-key-here
ALPACA_SECRET_KEY=your-alpaca-secret-key-here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# For live trading: https://api.alpaca.markets

# Trading Safety Controls
ENABLE_LIVE_ORDER_EXECUTION=false
ALWAYS_LIVE=false
LIVE_TRADING_ENABLED=false
PAPER_TRADING_ONLY=true

# Risk Management
MAX_POSITION_SIZE_PERCENT=5.0
MAX_DAILY_TRADES=50
MAX_PORTFOLIO_RISK_PERCENT=2.0
DEFAULT_STOP_LOSS_PERCENT=3.0
EMERGENCY_STOP_LOSS_PERCENT=10.0
MAX_DRAWDOWN_PERCENT=15.0

# Trading Engine Configuration
ENABLE_CRYPTO_ENGINE=true
ENABLE_OPTIONS_ENGINE=true
ENABLE_ADVANCED_ENGINE=true
ENABLE_MARKET_MAKER=true

# =============================================================================
# AI & REASONING CONFIGURATION
# =============================================================================
# AI Model Configuration
AI_ENABLED=true
GPT_OSS_ENABLED=false
OPENAI_API_KEY=your-openai-api-key-here

# AI Agent Configuration
AGENT_COORDINATION_ENABLED=true
HIERARCHICAL_AGENTS_ENABLED=true
AI_LEARNING_ENABLED=true
AI_FALLBACK_ENABLED=true

# Reasoning Configuration
THINKMESH_ENABLED=true
REASONING_DEPTH=3
CONFIDENCE_THRESHOLD=0.7

# =============================================================================
# MONITORING & LOGGING
# =============================================================================
# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=detailed
LOG_TO_FILE=true
LOG_FILE_PATH=logs/prometheus.log
LOG_ROTATION=daily
LOG_RETENTION_DAYS=30

# Metrics & Monitoring
ENABLE_METRICS=true
METRICS_COLLECTION_ENABLED=true
PROMETHEUS_METRICS_PORT=9090
GRAFANA_ENABLED=false
GRAFANA_PORT=3001

# Performance Monitoring
ENABLE_PERFORMANCE_MONITORING=true
TRACK_REQUEST_LATENCY=true
TRACK_DATABASE_PERFORMANCE=true
TRACK_TRADING_PERFORMANCE=true

# Health Checks
HEALTH_CHECKS_ENABLED=true
HEALTH_CHECK_INTERVAL=30
DEEP_HEALTH_CHECKS=false

# =============================================================================
# CACHING & PERFORMANCE
# =============================================================================
# Redis Configuration
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_DB=0

# Caching Configuration
ENABLE_CACHING=true
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=1000

# Performance Optimization
CONNECTION_POOL_SIZE=20
CONNECTION_POOL_MAX_OVERFLOW=30
QUERY_TIMEOUT_SECONDS=30

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
# Frontend Settings
ENABLE_FRONTEND=true
FRONTEND_BUILD_PATH=frontend/build
STATIC_FILES_PATH=static

# API Configuration for Frontend
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000/ws
REACT_APP_ENVIRONMENT=development

# =============================================================================
# CLOUD & DEPLOYMENT
# =============================================================================
# Cloud Configuration
CLOUD_PROVIDER=none
# Options: aws, gcp, azure, none

# AWS Configuration (if using AWS)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Docker Configuration
DOCKER_REGISTRY=
DOCKER_IMAGE_TAG=latest
CONTAINER_NAME=prometheus-trading

# Kubernetes Configuration
K8S_NAMESPACE=prometheus-trading
K8S_CLUSTER_NAME=prometheus-cluster

# Load Balancer Configuration
LOAD_BALANCER_ENABLED=false
NGINX_ENABLED=false

# =============================================================================
# BACKUP & DISASTER RECOVERY
# =============================================================================
# Backup Configuration
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_LOCATION=backups/

# Database Backup
DB_BACKUP_ENABLED=false
DB_BACKUP_COMPRESSION=true

# =============================================================================
# COMPLIANCE & REGULATORY
# =============================================================================
# Regulatory Compliance
REGULATORY_REPORTING_ENABLED=false
COMPLIANCE_MODE=false
AUDIT_TRAIL_ENABLED=true
AUDIT_RETENTION_DAYS=2555

# Trade Surveillance
TRADE_SURVEILLANCE_ENABLED=false
MARKET_ABUSE_DETECTION=false
SUSPICIOUS_ACTIVITY_MONITORING=false

# Data Retention
DATA_RETENTION_ENABLED=true
TRADE_DATA_RETENTION_DAYS=2555
LOG_DATA_RETENTION_DAYS=365
USER_DATA_RETENTION_DAYS=2555

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================
# Development Mode
DEV_MODE=false
DEBUG=false
HOT_RELOAD=false
MOCK_DATA=false

# Testing Configuration
TESTING=false
TEST_DATABASE_URL=sqlite:///test_prometheus.db
MOCK_TRADING_ENABLED=false
MOCK_AI_RESPONSES=false

# Development Tools
ENABLE_SWAGGER=true
ENABLE_REDOC=true
ENABLE_DEBUG_TOOLBAR=false

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Core Features
ENABLE_TRADING=true
ENABLE_AI_AGENTS=true
ENABLE_PORTFOLIO_MANAGEMENT=true
ENABLE_RISK_MANAGEMENT=true

# Advanced Features
ENABLE_OPTIONS_TRADING=false
ENABLE_CRYPTO_TRADING=false
ENABLE_FOREX_TRADING=false
ENABLE_FUTURES_TRADING=false

# Experimental Features
ENABLE_QUANTUM_COMPUTING=false
ENABLE_ADVANCED_AI=false
ENABLE_BLOCKCHAIN_INTEGRATION=false

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
# Market Data Providers
MARKET_DATA_PROVIDER=alpaca
# Options: alpaca, polygon, iex, yahoo

# News & Sentiment Data
NEWS_API_KEY=
SENTIMENT_ANALYSIS_ENABLED=false

# Economic Data
ECONOMIC_DATA_ENABLED=false
FRED_API_KEY=

# Social Media Monitoring
SOCIAL_MEDIA_MONITORING=false
TWITTER_API_KEY=
REDDIT_API_KEY=

# =============================================================================
# NOTIFICATIONS
# =============================================================================
# Email Notifications
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@prometheus-trading.com

# Slack Notifications
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#trading-alerts

# SMS Notifications
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Push Notifications
PUSH_NOTIFICATIONS_ENABLED=false

# =============================================================================
# CUSTOM CONFIGURATION
# =============================================================================
# Add your custom environment variables here
# CUSTOM_SETTING_1=value1
# CUSTOM_SETTING_2=value2
