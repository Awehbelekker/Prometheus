# 🚀 PROMETHEUS Trading Platform - Environment Configuration
# Copy this file to .env and configure your settings

# =============================================================================
# CORE SYSTEM CONFIGURATION
# =============================================================================

# API Configuration
REACT_APP_API_URL=http://localhost:8000
REACT_APP_ENVIRONMENT=production
REACT_APP_WS_URL=ws://localhost:8000/ws

# Frontend Configuration
PORT=3002
BROWSER=none
GENERATE_SOURCEMAP=false

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET_KEY=your_super_secret_jwt_key_change_this_in_production_min_32_chars

# Database Configuration
DATABASE_URL=sqlite:///./prometheus.db

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://127.0.0.1:3000,http://127.0.0.1:3002

# =============================================================================
# MARKET DATA PROVIDERS (OPTIONAL)
# =============================================================================

# Alpha Vantage Premium Market Data
# Get your API key at: https://www.alphavantage.co/support/#api-key
# Free tier: 5 calls/min, 500/day | Premium: Higher limits
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Polygon.io Premium (Unlimited S3 access + API)
# Premium credentials for institutional-grade market data
POLYGON_ACCESS_KEY_ID=your_polygon_access_key_id
POLYGON_SECRET_ACCESS_KEY=your_polygon_secret_access_key
POLYGON_S3_ENDPOINT=https://files.polygon.io
POLYGON_S3_BUCKET=flatfiles
POLYGON_API_KEY=your_polygon_api_key

# Financial Modeling Prep (Free: 250/day)
# Get your free API key at: https://financialmodelingprep.com/developer/docs
FMP_API_KEY=

# =============================================================================
# AI & MACHINE LEARNING (OPTIONAL)
# =============================================================================

# OpenAI API (for AI-powered trading intelligence)
# Get your API key at: https://platform.openai.com/api-keys
# Provides: Trading signals, sentiment analysis, portfolio optimization
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000

# Hugging Face API (for additional AI models - optional)
# Get your API key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# AI Model Configuration
AI_MODEL_PROVIDER=openai
AI_MODEL_NAME=gpt-4

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================

# Paper Trading Settings
PAPER_TRADING_ENABLED=true
INITIAL_PAPER_BALANCE=100000.00
MAX_POSITION_SIZE=10000.00
MAX_DAILY_TRADES=50

# Risk Management
STOP_LOSS_PERCENTAGE=5.0
TAKE_PROFIT_PERCENTAGE=10.0
MAX_PORTFOLIO_RISK=2.0

# =============================================================================
# SYSTEM PERFORMANCE
# =============================================================================

# Caching
CACHE_DURATION_SECONDS=30
REDIS_URL=redis://localhost:6379/0

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/prometheus.log

# =============================================================================
# MONITORING & ALERTS
# =============================================================================

# Email Notifications (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
NOTIFICATION_EMAIL=alerts@yourcompany.com

# Webhook Notifications (optional)
WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/DISCORD/WEBHOOK

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Debug Mode (set to false in production)
DEBUG=false
DEVELOPMENT_MODE=false

# Testing
TEST_MODE=false
MOCK_MARKET_DATA=false

# =============================================================================
# DEPLOYMENT SETTINGS
# =============================================================================

# Server Configuration
HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3002

# SSL Configuration (for production)
SSL_ENABLED=false
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# Domain Configuration (for production)
DOMAIN=localhost
SUBDOMAIN=prometheus

# =============================================================================
# NOTES
# =============================================================================

# 1. The system works perfectly with default values
# 2. API keys are optional - the system uses free tiers and fallbacks
# 3. Change JWT_SECRET_KEY in production for security
# 4. Enable SSL and configure domain for production deployment
# 5. Monitor logs/prometheus.log for system health
# 6. Visit http://localhost:8000/health to check system status
