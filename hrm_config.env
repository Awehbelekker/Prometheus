# HRM (Hierarchical Reasoning Model) Configuration
# Enable automatic model loading and checkpoint management

# Enable HRM auto-download (set to 1 to enable)
HRM_AUTO_DOWNLOAD=1

# HRM manifest URL for remote checkpoint updates
# Leave empty if no remote manifest is available
HRM_MANIFEST_URL=

# HRM reasoning weights (JSON format)
# These weights control how different reasoning levels contribute to decisions
HRM_WEIGHTS_JSON={"abstract_strategy": 0.25, "trade_params": 0.25, "patterns": 0.15, "sudoku": 0.15, "maze": 0.10, "risk_inverse": 0.10}

# HRM action thresholds
# Upper threshold for BUY decisions
HRM_ACTION_UPPER_BASE=0.58

# Lower threshold for SELL decisions  
HRM_ACTION_LOWER_BASE=0.42

# Risk-based band scaling for action thresholds
HRM_ACTION_RISK_BAND_SCALE=0.12

# HRM checkpoint directory
HRM_CHECKPOINT_DIR=hrm_checkpoints

# HRM version
HRM_VERSION=1.0.0

# Device for HRM processing (cpu or cuda)
HRM_DEVICE=cpu
