"/*":
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' https: data:; font-src 'self' data:; connect-src 'self' http://localhost:8000 ws://localhost:8000 https://prometheus-trader.com https://api.prometheus-trader.com https://www.prometheus-trader.com wss://prometheus-trader.com wss://api.prometheus-trader.com wss://ws.prometheus-trader.com;"
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Cache-Control: public, max-age=31536000, immutable

"/static/*":
  Cache-Control: public, max-age=31536000, immutable

"/index.html":
  Cache-Control: no-cache, no-store, must-revalidate

"/service-worker.js":
  Cache-Control: no-cache, no-store, must-revalidate

"/sw.js":
  Cache-Control: no-cache, no-store, must-revalidate

