          {/* Live Trade Stream */}
          <GlowingCard sx={{ p: 3, mt: 2 }}>
            <Typography variant="h6" sx={{ mb: 2, fontWeight: 700 }}>
              ⚡ Live Trade Stream
            </Typography>
            <LiveTradeStream trades={sampleTrades} />
          </GlowingCard>
        </Grid>

        {/* Gamification Badges */}
        <Grid item xs={12}>
          <GlowingCard sx={{ p: 3 }} glowColor="#9c27b0">
            <Typography variant="h6" sx={{ mb: 3, fontWeight: 700 }}>
              🏆 Achievement Badges
