      "⚡ Oracle consciousness at maximum"
    ]
  };

  const sampleBadges = [
    {
      id: 1,
      name: "Profit Hunter",
      description: "100 profitable trades achieved!",
      rarity: "uncommon",
      icon: "🎯"
    },
    {
      id: 2,
      name: "Prometheus Heir", 
