            <Grid container spacing={2}>
              {sampleBadges.map((badge, index) => (
                <Grid item xs={6} sm={4} md={3} lg={2} key={badge.id}>
                  <GamificationBadge badge={badge} isNew={index === 1} />
                </Grid>
              ))}
            </Grid>
          </GlowingCard>
        </Grid>
      </Grid>

      {/* Floating Action Buttons */}
      <Box sx={{ position: 'fixed', bottom: 20, right: 20 }}>
        <motion.div
          animate={{
            y: [0, -10, 0],
          }}
          transition={{
            duration: 2,
            repeat: Infinity,
            repeatType: "reverse"
          }}
        >
          <Fab
            color="primary"
            sx={{
              background: 'linear-gradient(45deg, #ff6b00, #ff8f00)',
              '&:hover': {
                background: 'linear-gradient(45deg, #ff8f00, #ffa000)',
                transform: 'scale(1.1)'
              },
              transition: 'all 0.3s ease'
            }}
          >
            <AutoAwesome />
          </Fab>
        </motion.div>
      </Box>
    </Box>
  );
};

export default RevolutionaryTradingInterface;
