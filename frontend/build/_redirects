# Redirect all traffic to HTTPS
http://prometheus-trader.com/* https://prometheus-trader.com/:splat 301!
http://www.prometheus-trader.com/* https://prometheus-trader.com/:splat 301!

# Redirect www to non-www
https://www.prometheus-trader.com/* https://prometheus-trader.com/:splat 301!

# API proxy (if needed)
/api/* https://api.prometheus-trader.com/:splat 200

# WebSocket proxy (if needed)
/ws/* wss://api.prometheus-trader.com/ws/:splat 200

# SPA fallback - serve index.html for all routes
/*    /index.html   200

